    "/v1/telephony/import": {
      "post": {
        "tags": [
          "Telephony"
        ],
        "summary": "Import phone number",
        "description": "Import a phone number from custom telephony and bind agents",
        "security": [
          {
            "BearerAuth": []
          },
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phone_number",
                  "termination_uri"
                ],
                "properties": {
                  "phone_number": {
                    "type": "string",
                    "description": "E.164 format phone number",
                    "example": "+14157774444"
                  },
                  "termination_uri": {
                    "type": "string",
                    "description": "SIP trunk termination URI",
                    "example": "sip.uk.didlogic.net"
                  },
                  "direction": {
                    "type": "string",
                    "enum": [
                      "inbound",
                      "outbound",
                      "both"
                    ],
                    "description": "Which direction(s) to configure - inbound only, outbound only, or both. Defaults to both if not specified.",
                    "example": "both"
                  },
                  "sip_auth_username": {
                    "type": "string",
                    "description": "SIP authentication username (required)",
                    "example": "93329"
                  },
                  "sip_auth_password": {
                    "type": "string",
                    "description": "SIP authentication password (required)",
                    "example": "@@DidlogicSip00@@"
                  },
                  "inbound_agent_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Agent ID for inbound calls"
                  },
                  "outbound_agent_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Agent ID for outbound calls"
                  },
                  "inbound_agent_version": {
                    "type": "integer",
                    "description": "Inbound agent version"
                  },
                  "outbound_agent_version": {
                    "type": "integer",
                    "description": "Outbound agent version"
                  },
                  "nickname": {
                    "type": "string",
                    "description": "Friendly name for the phone number",
                    "example": "Main Support Line"
                  },
                  "inbound_webhook_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Webhook URL for inbound call events"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Phone number imported successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "phone_number": {
                          "type": "string"
                        },
                        "inbound_sip_trunk_id": {
                          "type": "string",
                          "nullable": true
                        },
                        "outbound_sip_trunk_id": {
                          "type": "string",
                          "nullable": true
                        },
                        "auth_state": {
                          "type": "string",
                          "enum": [
                            "authenticated",
                            "not_authenticated",
                            "server_error",
                            "not_verified"
                          ]
                        },
                        "auth_state_message": {
                          "type": "string",
                          "nullable": true
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Phone number already exists"
          }
        }
      }
    },
